# Run lint-staged to check and fix changed files
npx lint-staged

# Store exit status from lint-staged
LINT_STAGED_EXIT=$?

# Run PHP tests with Pest
echo ""
echo "🧪 Running PHP tests..."
PHP_VERSION=$(php -r 'echo PHP_VERSION;' 2>/dev/null || true)
if [ -z "$PHP_VERSION" ]; then
  echo "⚠️  PHP not found locally, skipping PHP tests in pre-commit. CI will enforce tests."
  TESTS_EXIT=0
elif [ "$(printf '%s\n' "8.4.0" "$PHP_VERSION" | sort -V | head -n1)" = "8.4.0" ]; then
  php artisan test --env=testing
  TESTS_EXIT=$?
else
  echo "⚠️  Local PHP version is $PHP_VERSION (< 8.4.0), skipping PHP tests in pre-commit. CI will enforce tests."
  TESTS_EXIT=0
fi

# If either failed, exit with error
if [ $LINT_STAGED_EXIT -ne 0 ] || [ $TESTS_EXIT -ne 0 ]; then
  if [ $LINT_STAGED_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Linting/formatting check failed. Please fix the issues above."
  fi
  if [ $TESTS_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Some tests failed. Please fix the issues above."
  fi
  exit 1
fi

echo ""
echo "✅ All checks passed!"
